{
  "name": "analytics-checker",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron:dev": "electron electron/main.js",
    "build:next": "next build",
    "build:electron": "electron-builder",
    "dist": "npm run build:next && npm run build:electron",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.analyticschecker.desktop",
    "productName": "Analytics Checker",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/standalone/**/*",
      {
        "from": ".next/static",
        "to": ".next/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      "public/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      "platform-tools/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
